# Add your Google Gemini / Generative Language API key here.
# Get an API key from https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_api_key_here

# Optional: change the model if needed.
# Common Gemini models include: gemini-2.5-flash, gemini-1.5-mini, gemini-1.5-pro, gemini-1.0
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: override base url (usually not necessary)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
